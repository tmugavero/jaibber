{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Jaibber",
  "version": "0.1.2",
  "identifier": "com.jaibber.hub",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5174",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Jaibber",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' blob: https://api.jaibber.com; connect-src 'self' https://api.jaibber.com https://*.ably.io wss://*.ably.io; font-src 'self'"
    },
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/tmugavero/jaibber/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDA1MTE0NEFFNjhCRjdBMTYKUldRV2VyOW9ya1FSQmRTU1BqcWlzT3dZbXZhUHJOMDRFelM3YjRRd1RkWFFTcG83RHVVa0NOMkwK"
    }
  }
}
